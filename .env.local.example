# Copy this file to ".env.local" and fill in the two values from your Supabase project.
# Find them in the Supabase dashboard under: Project Settings -> API.

# Your project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your project's public "anon" key (safe to expose in the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Payday recap emails (optional): create a free API key at resend.com.
# Until set, recap emails are logged to the server console instead.
# RESEND_API_KEY=re_...
# RESEND_FROM=Till Payday <onboarding@resend.dev>
